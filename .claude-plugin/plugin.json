{
  "name": "memory",
  "version": "1.0.0",
  "description": "Cross-platform memory system. 3-tier architecture, vault sync, session hooks, weekly consolidation.",
  "author": {
    "name": "maxtechera",
    "url": "https://github.com/maxtechera"
  },
  "homepage": "https://github.com/maxtechera/memory",
  "repository": "https://github.com/maxtechera/memory",
  "license": "MIT",
  "category": "productivity",
  "keywords": [
    "memory",
    "obsidian",
    "vault-sync",
    "cross-platform",
    "session-hooks",
    "consolidation",
    "skill-first"
  ],
  "skills": ["./"],
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash hooks/session-start-vault.sh"
      },
      {
        "type": "command",
        "command": "bash hooks/force-mcp-connectors.sh"
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "bash hooks/pre-compact-vault.sh"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash hooks/session-stop-vault.sh",
        "async": true
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "bash hooks/agent-start.sh",
        "async": true
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": "bash hooks/agent-stop.sh",
        "async": true
      }
    ],
    "Notification": [
      {
        "matcher": "compact",
        "type": "command",
        "command": "bash hooks/compact-notification.sh"
      }
    ]
  }
}
